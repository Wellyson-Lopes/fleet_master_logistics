<div class="sys-dash-topbar">
  <div>
    <div class="sys-dash-title">Dashboard</div>
    <div class="sys-dash-subtitle"><%= I18n.l(Date.current, format: :long) %> · Boa tarde, <%= current_user.name.split.first %></div>
  </div>
  <div class="sys-flex sys-gap-2">
    <button class="sys-btn sys-btn-ghost sys-btn-sm">Esta semana</button>
    <button class="sys-btn sys-btn-primary sys-btn-sm">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="sys-w-13 sys-h-13"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nova Viagem
    </button>
  </div>
</div>

<!-- Sessão Ativa Info -->
<div class="sys-mb-6 sys-flex sys-flex-wrap sys-gap-2 sys-items-center">
  <div class="sys-badge sys-badge-green">
    <span class="sys-dot sys-bg-green-500 sys-animate-pulse"></span>
    <%= current_user.company_name %> · <%= current_user.owner? ? "Administrador" : "Colaborador" %>
  </div>
  <div class="sys-badge sys-badge-blue">
    CNPJ: <%= current_user.cnpj %>
  </div>
</div>

<!-- KPIs -->
<!-- MOCK DATA: Os valores abaixo são estáticos e devem ser substituídos por dados reais da empresa -->
<div class="sys-kpis-row">
  <div class="sys-kpi-card blue">
    <div class="sys-kpi-icon blue"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg></div>
    <div class="sys-kpi-value">8</div>
    <div class="sys-kpi-label">Viagens Ativas</div>
    <div class="sys-kpi-delta up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="sys-w-9 sys-h-9"><polyline points="18 15 12 9 6 15"/></svg>+2</div>
  </div>
  <div class="sys-kpi-card teal">
    <div class="sys-kpi-icon teal"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
    <div class="sys-kpi-value">47</div>
    <div class="sys-kpi-label">Entregas Esta Semana</div>
    <div class="sys-kpi-delta up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="sys-w-9 sys-h-9"><polyline points="18 15 12 9 6 15"/></svg>+12%</div>
  </div>
  <div class="sys-kpi-card amber">
    <div class="sys-kpi-icon amber"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg></div>
    <div class="sys-kpi-value">3</div>
    <div class="sys-kpi-label">Ocorrências Abertas</div>
    <div class="sys-kpi-delta down"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="sys-w-9 sys-h-9"><polyline points="6 9 12 15 18 9"/></svg>Atenção</div>
  </div>
  <div class="sys-kpi-card green">
    <div class="sys-kpi-icon green"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
    <div class="sys-kpi-value">12</div>
    <div class="sys-kpi-label">Veículos na Frota</div>
    <div class="sys-kpi-delta up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="sys-w-9 sys-h-9"><polyline points="18 15 12 9 6 15"/></svg>9 livres</div>
  </div>
</div>

<div class="sys-dash-content-grid">
  <!-- Viagens recentes -->
  <!-- MOCK DATA: Listagem estática de viagens -->
  <div class="sys-card sys-p-16">
    <div class="sys-card-header sys-mb-12">
      <div class="sys-card-title">Viagens Recentes</div>
      <button class="sys-btn sys-btn-ghost sys-btn-sm">Ver todas</button>
    </div>
    <div class="sys-flex sys-flex-col sys-gap-2">
      <div class="sys-item-row">
        <div class="sys-item-icon-box sys-bg-amber-light-10">
          <svg fill="none" viewBox="0 0 24 24" stroke="#F59E0B" stroke-width="2" class="sys-w-16 sys-h-16"><rect x="1" y="3" width="15" height="13"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="sys-item-info">
          <div class="sys-item-title">Carlos Silva · ABC-1234</div>
          <div class="sys-item-subtitle">Construtora Nordeste · 240 sacos</div>
        </div>
        <span class="sys-badge sys-badge-amber">Em Rota</span>
      </div>
      <div class="sys-item-row-alt">
        <div class="sys-item-icon-box sys-bg-red-light-10">
          <svg fill="none" viewBox="0 0 24 24" stroke="#EF4444" stroke-width="2" class="sys-w-16 sys-h-16"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        </div>
        <div class="sys-item-info">
          <div class="sys-item-title">Pedro Alves · XYZ-5678</div>
          <div class="sys-item-subtitle">Ocorrência: Pneu furado</div>
        </div>
        <span class="sys-badge sys-badge-red">Alerta</span>
      </div>
      <div class="sys-item-row">
        <div class="sys-item-icon-box sys-bg-teal-light-10">
          <svg fill="none" viewBox="0 0 24 24" stroke="#10B981" stroke-width="2" class="sys-w-16 sys-h-16"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="sys-item-info">
          <div class="sys-item-title">Marcos Oliveira · DEF-9012</div>
          <div class="sys-item-subtitle">210 km · Distribuição Centro</div>
        </div>
        <span class="sys-badge sys-badge-teal">Concluída</span>
      </div>
    </div>
  </div>

  <!-- Status da Frota -->
  <!-- MOCK DATA: Indicadores de frota estáticos -->
  <div class="sys-card sys-p-16">
    <div class="sys-card-header sys-mb-12">
      <div class="sys-card-title">Status da Frota</div>
    </div>
    <div class="sys-status-list">
      <div>
        <div class="sys-flex sys-justify-between sys-mb-1 sys-text-11">
          <span class="sys-text-gray-600">Disponíveis</span>
          <span class="sys-font-bold sys-text-green">9/12</span>
        </div>
        <div class="sys-progress-bar"><div class="sys-progress-fill sys-bg-green sys-w-75"></div></div>
      </div>
      <div>
        <div class="sys-flex sys-justify-between sys-mb-1 sys-text-11">
          <span class="sys-text-gray-600">Em Viagem</span>
          <span class="sys-font-bold sys-text-amber">2/12</span>
        </div>
        <div class="sys-progress-bar"><div class="sys-progress-fill sys-bg-amber sys-w-17"></div></div>
      </div>
      <div>
        <div class="sys-flex sys-justify-between sys-mb-1 sys-text-11">
          <span class="sys-text-gray-600">Manutenção</span>
          <span class="sys-font-bold sys-text-red">1/12</span>
        </div>
        <div class="sys-progress-bar"><div class="sys-progress-fill sys-bg-red sys-w-8"></div></div>
      </div>
    </div>
    <div class="sys-mt-6 sys-pt-12 sys-border-top">
      <div class="sys-text-11 sys-font-bold sys-text-gray-500 sys-mb-2">Alertas de Vencimento</div>
      <div class="sys-alert-list">
        <div class="sys-flex sys-justify-between sys-text-11">
          <span class="sys-text-gray-700">🚨 GHI-3456 · Seguro</span>
          <span class="sys-text-red sys-font-bold">Vencido</span>
        </div>
        <div class="sys-flex sys-justify-between sys-text-11">
          <span class="sys-text-gray-700">⚠️ ABC-1234 · Vistoria</span>
          <span class="sys-text-amber sys-font-bold">8 dias</span>
        </div>
      </div>
    </div>
  </div>
</div>
