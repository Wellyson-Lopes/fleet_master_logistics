<% if resource.errors.any? %>
  <div class="bg-red-50 border-l-4 border-red-500 p-6 mb-6 rounded-2xl shadow-sm animate-in fade-in slide-in-from-top-2 duration-300" data-turbo-temporary>
    <div class="flex items-center mb-3">
      <svg class="h-5 w-5 text-red-500 mr-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
      </svg>
      <span class="text-red-800 font-bold text-[14px]">Verifique os campos abaixo:</span>
    </div>
    <ul class="text-red-700 text-[13px] space-y-1.5 ml-9 list-disc font-medium">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
