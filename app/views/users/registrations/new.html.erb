<div class='min-h-[80vh] flex items-center justify-center px-4 py-12'>
  <div class='w-full max-w-[500px] bg-white rounded-[24px] shadow-[0_20px_50px_rgba(0,0,0,0.08)] border border-gray-100 p-8 md:p-10'>
    <h3 class='text-[24px] font-bold text-gray-900 text-center mb-2'>Crie sua conta</h3>
    <p class='text-[14px] text-gray-500 text-center mb-8 leading-relaxed'>Experimente o FleetMaster gratuitamente por 14 dias.</p>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render 'users/shared/error_messages', resource: resource %>
      <div class='space-y-4'>
        <div>
          <%= f.label :name, 'Nome Completo', class: 'block text-[13px] font-semibold text-gray-700 mb-1.5 ml-1' %>
          <%= f.text_field :name, autofocus: true, class: 'w-full h-[48px] px-4 bg-gray-50 border border-gray-200 rounded-[12px] text-[15px] focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all' %>
        </div>
        <div>
          <%= f.label :email, 'E-mail Corporativo', class: 'block text-[13px] font-semibold text-gray-700 mb-1.5 ml-1' %>
          <%= f.email_field :email, class: 'w-full h-[48px] px-4 bg-gray-50 border border-gray-200 rounded-[12px] text-[15px] focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all' %>
        </div>
        <div class='grid grid-cols-2 gap-3'>
          <div>
            <%= f.label :company_name, 'Nome da Empresa', class: 'block text-[13px] font-semibold text-gray-700 mb-1.5 ml-1' %>
            <%= f.text_field :company_name, class: 'w-full h-[48px] px-4 bg-gray-50 border border-gray-200 rounded-[12px] text-[15px] focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all' %>
          </div>
          <div>
            <%= f.label :cnpj, 'CNPJ', class: 'block text-[13px] font-semibold text-gray-700 mb-1.5 ml-1' %>
            <%= f.text_field :cnpj, class: 'w-full h-[48px] px-4 bg-gray-50 border border-gray-200 rounded-[12px] text-[15px] focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all' %>
          </div>
        </div>
        <div>
          <%= f.label :password, 'Senha', class: 'block text-[13px] font-semibold text-gray-700 mb-1.5 ml-1' %>
          <%= f.password_field :password, class: 'w-full h-[48px] px-4 bg-gray-50 border border-gray-200 rounded-[12px] text-[15px] focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all' %>
        </div>
        <div class='pt-4'>
          <%= f.button type: :submit, class: 'w-full h-[54px] bg-blue-600 hover:bg-blue-700 text-white font-bold text-[16px] rounded-[14px] shadow-lg shadow-blue-500/30 transition-all transform active:scale-[0.98] cursor-pointer flex items-center justify-center' do %>
            Criar Minha Conta
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
