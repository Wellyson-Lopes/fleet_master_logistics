<!-- Formulário de Cadastro (Fidelidade ao Mockup) -->
<div id="register-section" data-auth-modal-target="registerSection" class="hidden">
  <div class="lp-modal-logo">
    <%= image_tag "logo-full.svg", alt: "FleetMaster Logo", class: "h-12 w-auto" %>
  </div>

  <h3 class="lp-modal-title">Crie sua conta</h3>
  <p class="lp-modal-sub">Experimente o FleetMaster gratuitamente por 14 dias.</p>

  <form data-action="submit->auth-modal#submitRegister">
    <div class="grid grid-cols-2 gap-3 mb-4">
      <div>
        <label class="lp-modal-label">Nome</label>
        <input type="text" class="lp-modal-input" placeholder="João" required>
      </div>
      <div>
        <label class="lp-modal-label">Sobrenome</label>
        <input type="text" class="lp-modal-input" placeholder="Silva" required>
      </div>
    </div>
    
    <div class="lp-modal-group">
      <label class="lp-modal-label">E-mail da Empresa</label>
      <input type="email" class="lp-modal-input" placeholder="ex: joao@empresa.com.br" required>
    </div>
    
    <div class="lp-modal-group">
      <label class="lp-modal-label">Nome da Empresa</label>
      <input type="text" class="lp-modal-input" placeholder="ex: Distribuidora Nordeste Ltda" required>
    </div>
    
    <div class="lp-modal-group">
      <label class="lp-modal-label">Criar Senha</label>
      <input type="password" class="lp-modal-input" placeholder="Mínimo 8 caracteres" required>
    </div>
 
    <button type="submit" class="lp-modal-submit">
      Criar Conta Grátis
    </button>

    <div class="lp-modal-switch">
      Já possui conta? 
      <button type="button" data-action="click->auth-modal#showLogin">Entrar →</button>
    </div>
  </form>
</div>
