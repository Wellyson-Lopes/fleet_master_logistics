<!-- Formulário de Cadastro (Integrado com Devise) -->
<div id="register-section" data-auth-modal-target="registerSection" class="hidden">
  <div class="lp-modal-logo">
    <%= image_tag "logo-full.svg", alt: "FleetMaster Logo", class: "h-12 w-auto" %>
  </div>

  <h3 class="lp-modal-title">Crie sua conta</h3>
  <p class="lp-modal-sub">Experimente o FleetMaster gratuitamente por 14 dias.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "users/shared/error_messages", resource: resource %>

    <div class="lp-modal-group">
      <%= f.label :name, "Nome Completo", class: "lp-modal-label" %>
      <%= f.text_field :name, class: "lp-modal-input", placeholder: "Ex: João Silva", required: true %>
    </div>
    
    <div class="lp-modal-group">
      <%= f.label :email, "E-mail da Empresa", class: "lp-modal-label" %>
      <%= f.email_field :email, class: "lp-modal-input", placeholder: "ex: joao@empresa.com.br", required: true %>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div class="lp-modal-group">
        <%= f.label :company_name, "Nome da Empresa", class: "lp-modal-label" %>
        <%= f.text_field :company_name, class: "lp-modal-input", placeholder: "Ex: Horus Logística", required: true %>
      </div>
      <div class="lp-modal-group">
        <%= f.label :cnpj, "CNPJ (Opcional)", class: "lp-modal-label" %>
        <%= f.text_field :cnpj, class: "lp-modal-input", placeholder: "00.000.000/0001-00" %>
      </div>
    </div>
    
    <div class="lp-modal-group">
      <%= f.label :password, "Criar Senha", class: "lp-modal-label" %>
      <%= f.password_field :password, class: "lp-modal-input", placeholder: "Mínimo 6 caracteres", required: true %>
    </div>
 
    <%= f.submit "Criar Conta Grátis", class: "lp-modal-submit" %>

    <div class="lp-modal-switch">
      Já possui conta? 
      <button type="button" data-action="click->auth-modal#showLogin">Entrar →</button>
    </div>
  <% end %>
</div>
