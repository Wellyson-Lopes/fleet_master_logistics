<div class='min-h-[80vh] flex items-center justify-center px-4 py-12'>
  <div class='w-full max-w-[440px] bg-white rounded-[24px] shadow-[0_20px_50px_rgba(0,0,0,0.08)] border border-gray-100 p-8 md:p-10'>
    <h3 class='text-[24px] font-bold text-gray-900 text-center mb-2'>Recuperar Senha</h3>
    <p class='text-[14px] text-gray-500 text-center mb-8 leading-relaxed'>Esqueceu sua senha? Insira seu e-mail e enviaremos as instruções.</p>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render 'users/shared/error_messages', resource: resource %>
      <div class='space-y-6'>
        <div>
          <%= f.label :email, 'E-mail de Cadastro', class: 'block text-[13px] font-semibold text-gray-700 mb-2 ml-1' %>
          <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'w-full h-[52px] px-5 bg-gray-50 border border-gray-200 rounded-[14px] text-[15px] text-gray-900 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all', placeholder: 'ex: seu@email.com.br', required: true %>
        </div>
        <div>
          <%= f.button type: :submit, class: 'w-full h-[54px] bg-blue-600 hover:bg-blue-700 text-white font-bold text-[16px] rounded-[14px] shadow-lg shadow-blue-500/30 transition-all transform active:scale-[0.98] cursor-pointer flex items-center justify-center' do %>
            Enviar Instruções
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
