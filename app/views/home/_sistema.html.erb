<!-- SEÇÃO SISTEMA WEB E APP MOBILE -->
<section class="lp-mockup-section" id="sistema">
  <div class="lp-mockup-inner">
    
    <!-- Painel Web do Gestor -->
    <div class="lp-mockup-grid mb-32">
      <div class="lp-mockup-text">
        <div class="lp-section-label">Sistema Web</div>
        <h2 class="lp-section-title">Painel completo para o gestor</h2>
        <p>Dashboard com KPIs em tempo real, tabelas de viagens, controle de frota e relatórios gerenciais — tudo em uma interface rápida e intuitiva.</p>
        
        <div class="lp-mockup-checks">
          <div class="lp-mockup-check">
            <div class="lp-check-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span>Dashboard com métricas ao vivo e alertas</span>
          </div>
          <div class="lp-mockup-check">
            <div class="lp-check-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span>Tabelas filtráveis de viagens e veículos</span>
          </div>
          <div class="lp-mockup-check">
            <div class="lp-check-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span>Exportação de relatórios em PDF e Excel</span>
          </div>
        </div>
      </div>

      <div class="lp-web-mockup">
        <div class="lp-web-top">
          <div class="lp-web-dots"><span></span><span></span><span></span></div>
          <div class="lp-url-bar">app.fleetmaster.com.br</div>
        </div>
        <div class="lp-web-content">
          <div class="lp-chart-area">
            <div class="lp-chart-head">
              <div class="lp-chart-head-title">Entregas por semana</div>
              <div class="lp-chart-head-badge">↑ 18% este mês</div>
            </div>
            <div class="lp-chart-bars">
              <div class="lp-chart-bar-wrap"><div class="lp-chart-bar lp-chart-bar-55"></div></div>
              <div class="lp-chart-bar-wrap"><div class="lp-chart-bar lp-chart-bar-70"></div></div>
              <div class="lp-chart-bar-wrap"><div class="lp-chart-bar lp-chart-bar-48"></div></div>
              <div class="lp-chart-bar-wrap"><div class="lp-chart-bar lp-chart-bar-88"></div></div>
            </div>
          </div>
          <div class="lp-stats-row">
            <div class="lp-stat-mini">
              <div class="lp-stat-mini-val lp-stat-blue">R$ 28k</div>
              <div class="lp-stat-mini-label">Custo de frota</div>
            </div>
            <div class="lp-stat-mini">
              <div class="lp-stat-mini-val lp-stat-teal">94%</div>
              <div class="lp-stat-mini-label">Entregas no prazo</div>
            </div>
            <div class="lp-stat-mini">
              <div class="lp-stat-mini-val lp-stat-amber">3</div>
              <div class="lp-stat-mini-label">Ocorrências abertas</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- App do Motorista -->
    <div class="lp-mockup-grid reverse">
      <div class="lp-mockup-text">
        <div class="lp-section-label">App Mobile</div>
        <h2 class="lp-section-title">App nativo para o motorista</h2>
        <p>O motorista baixa o app, faz login e já tem acesso às viagens do dia, roteiros de entrega e canal direto com o gestor — sem papelada.</p>
        
        <div class="lp-mockup-checks">
          <div class="lp-mockup-check">
            <div class="lp-check-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span>Confirmação de entrega com foto e assinatura</span>
          </div>
          <div class="lp-mockup-check">
            <div class="lp-check-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span>Registro de ocorrências e abastecimentos</span>
          </div>
          <div class="lp-mockup-check">
            <div class="lp-check-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span>Funciona offline e sincroniza ao recuperar sinal</span>
          </div>
        </div>
      </div>

      <div class="lp-phone">
        <div class="lp-phone-notch"></div>
        <div class="lp-phone-screen">
          <div class="lp-mob-header">
            <div>
              <div class="lp-mob-greet">Bom dia,</div>
              <div class="lp-mob-name">Carlos Silva</div>
            </div>
            <div class="lp-mob-avatar">CS</div>
          </div>
          <div class="lp-mob-card">
            <div class="lp-mob-card-label">Viagem Ativa</div>
            <div class="lp-mob-card-title">ABC-1234 · Volvo FH</div>
            <div class="lp-mob-card-sub">Recife → Caruaru</div>
            <div class="lp-mob-tag"><span>●</span> Em Rota</div>
          </div>
          <button class="lp-mob-btn">Confirmar Entrega</button>
          <div class="lp-mob-list-title">Próximas paradas</div>
          <div class="lp-mob-item">
            <div class="lp-mob-item-icon lp-bg-teal-faint"><svg fill="none" viewBox="0 0 24 24" stroke="var(--teal)" stroke-width="2.5" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg></div>
            <div class="lp-mob-item-text">
              <div class="lp-mob-item-name">Construtora X</div>
              <div class="lp-mob-item-sub">Av. das Nações, 1200</div>
            </div>
          </div>
          <div class="lp-mob-bottom">
            <div class="lp-mob-bottom-item active">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              <span>Início</span>
            </div>
            <div class="lp-mob-bottom-item">
              <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Perfil</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </div>
</section>
