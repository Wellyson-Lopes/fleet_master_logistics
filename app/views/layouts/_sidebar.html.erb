<div class="sys-dash-sidebar">
  <div class="sys-sidebar-logo">
    <% if current_user.company_logo.attached? %>
      <%= image_tag current_user.company_logo, class: "sys-w-8 sys-h-8 sys-rounded-md sys-object-cover" %>
    <% else %>
      <div class="sys-logo-icon-box">
        <svg viewBox="0 0 24 24" class="sys-w-14 sys-h-14" fill="white"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
      </div>
    <% end %>
    <span class="sys-text-13 sys-font-bold sys-text-white"><%= current_user.company_name %></span>
  </div>

  <div class="sys-sidebar-group-label">Principal</div>
  <%= link_to dashboard_index_path, class: "sys-sidebar-item #{'active' if controller_name == 'dashboard'}" do %>
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    Dashboard
  <% end %>
  
  <a href="#" class="sys-sidebar-item">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
    Viagens
    <span class="sys-sidebar-count">8</span>
  </a>

  <a href="#" class="sys-sidebar-item">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    Frota
  </a>

  <a href="#" class="sys-sidebar-item">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    Motoristas
  </a>

  <%= link_to teams_path, class: "sys-sidebar-item #{'active' if controller_name == 'teams'}" do %>
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
    Gestão de Equipe
  <% end %>

  <div class="sys-sidebar-group-label">Operação</div>
  <a href="#" class="sys-sidebar-item">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/></svg>
    Ocorrências
    <span class="sys-sidebar-count red">3</span>
  </a>

  <a href="#" class="sys-sidebar-item">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547"/></svg>
    Abastecimentos
  </a>

  <a href="#" class="sys-sidebar-item">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    Relatórios
  </a>

  <div class="sys-mt-auto sys-pt-12 sys-border-top sys-border-white-5">
    <%= button_to destroy_user_session_path, method: :delete, class: "sys-sidebar-item sys-w-full sys-text-left sys-bg-transparent sys-border-none sys-p-0 sys-cursor-pointer" do %>
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Sair
    <% end %>
  </div>
</div>
