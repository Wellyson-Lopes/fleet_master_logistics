<div class='min-h-[80vh] flex items-center justify-center px-4 py-12'>
  <div class='w-full max-w-[440px] bg-white rounded-[24px] shadow-[0_20px_50px_rgba(0,0,0,0.08)] border border-gray-100 p-8 md:p-10'>
    
    <h3 class='text-[24px] font-bold text-gray-900 text-center mb-2'>Definir sua Senha</h3>
    <p class='text-[14px] text-gray-500 text-center mb-8 leading-relaxed'>
      Você foi convidado para a plataforma. Escolha uma senha segura para ativar sua conta.
    </p>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :put }) do |f| %>
      <%= render 'users/shared/error_messages', resource: resource %>
      <%= f.hidden_field :invitation_token %>

      <div class='space-y-6'>
        <% if f.object.class.require_password_on_activating %>
          <div>
            <%= f.label :password, 'Nova Senha', class: 'block text-[13px] font-semibold text-gray-700 mb-2 ml-1' %>
            <%= f.password_field :password, autofocus: true, 
                class: 'w-full h-[52px] px-5 bg-gray-50 border border-gray-200 rounded-[14px] text-[15px] text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A6CF6]/20 focus:border-[#1A6CF6] transition-all duration-200', 
                placeholder: 'Mínimo 8 caracteres', required: true %>
          </div>

          <div>
            <%= f.label :password_confirmation, 'Confirmar Senha', class: 'block text-[13px] font-semibold text-gray-700 mb-2 ml-1' %>
            <%= f.password_field :password_confirmation, 
                class: 'w-full h-[52px] px-5 bg-gray-50 border border-gray-200 rounded-[14px] text-[15px] text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1A6CF6]/20 focus:border-[#1A6CF6] transition-all duration-200', 
                placeholder: '••••••••', required: true %>
          </div>
        <% end %>

        <div>
          <%= f.button type: :submit, 
              class: 'w-full h-[54px] bg-[#1A6CF6] hover:bg-[#1559D1] text-white font-bold text-[16px] rounded-[14px] shadow-[0_10px_20px_rgba(26,108,246,0.2)] transition-all duration-300 transform active:scale-[0.98] cursor-pointer flex items-center justify-center' do %>
            Ativar minha Conta
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
