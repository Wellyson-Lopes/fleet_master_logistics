<div class="lp-wrap flex items-center justify-center min-h-[calc(100vh-64px)] py-12 px-4">
  <div class="lp-modal !transform-none !static">
    <div class="lp-modal-logo">
      <%= image_tag "logo-full.svg", alt: "FleetMaster Logo", class: "h-12 w-auto" %>
    </div>

    <h3 class="lp-modal-title"><%= t "devise.invitations.new.header" %></h3>
    <p class="lp-modal-sub">Envie um convite por e-mail para um novo motorista.</p>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "drivers/shared/error_messages", resource: resource %>

      <% resource.class.invite_key_fields.each do |field| -%>
        <div class="lp-modal-group">
          <%= f.label field, class: "lp-modal-label" %>
          <%= f.text_field field, class: "lp-modal-input", placeholder: "E-mail do motorista", required: true, autofocus: true %>
        </div>
      <% end -%>

      <div class="lp-modal-group">
        <%= f.label :cnpj, "CNPJ da Empresa", class: "lp-modal-label" %>
        <%= f.text_field :cnpj, class: "lp-modal-input", placeholder: "00.000.000/0001-00", required: true %>
      </div>

      <%= f.submit t("devise.invitations.new.submit_button"), class: "lp-modal-submit" %>
    <% end %>
  </div>
</div>
